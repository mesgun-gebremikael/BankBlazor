@page "/transactions"
@inject HttpClient Http

<h3>Transactions</h3>

<p>Här kan du hämta kundens konton och se saldo.</p>

<div class="mb-3">
    <label>Kundens id:</label>
    <input @bind="_customerId" class="form-control" />
    <button class="btn btn-primary mt-2" @onclick="LoadAccounts">Hämta konton</button>
</div>

@if (_accounts.Count > 0)
{
    <h5>Kundens konton</h5>
    <table class="table">
        <thead>
            <tr>
                <th>Kontonummer</th>
                <th>Saldo</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var account in _accounts)
            {
                <tr>
                    <td>@account.AccountId</td>
                    <td>@account.Balance.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>
}

<hr />

<h5>Insättning</h5>

<div class="mb-3">
    <label>Kontonummer:</label>
    <input @bind="_depositAccountId" class="form-control" />

    <label>Belopp:</label>
    <input @bind="_depositAmount" class="form-control" />

    <button class="btn btn-success mt-2" @onclick="Deposit">
        Gör insättning
    </button>
</div>

<hr />

<h5>Uttag</h5>

<div class="mb-3">
    <label>Kontonummer:</label>
    <input @bind="_withdrawAccountId" class="form-control" />

    <label>Belopp:</label>
    <input @bind="_withdrawAmount" class="form-control" />

    <button class="btn btn-warning mt-2" @onclick="Withdraw">
        Gör uttag
    </button>
</div>

<hr />

<h5>Överföring</h5>

<div class="mb-3">
    <label>Från konto:</label>
    <input @bind="_fromAccountId" class="form-control" />

    <label>Till konto:</label>
    <input @bind="_toAccountId" class="form-control" />

    <label>Belopp:</label>
    <input @bind="_transferAmount" class="form-control" />

    <button class="btn btn-danger mt-2" @onclick="Transfer">
        Gör överföring
    </button>
</div>

@code {
    private int _customerId;
    private List<AccountDto> _accounts = new();

    private int _depositAccountId;
    private decimal _depositAmount;

    private int _withdrawAccountId;
    private decimal _withdrawAmount;

    private int _fromAccountId;
    private int _toAccountId;
    private decimal _transferAmount;

    private async Task LoadAccounts()
    {
        var result = await Http.GetFromJsonAsync<List<AccountDto>>($"api/accounts/customer/{_customerId}");
        _accounts = result ?? new List<AccountDto>();
    }

    private async Task Deposit()
    {
        await Http.PostAsJsonAsync("api/accounts/deposit", new
        {
            accountId = _depositAccountId,
            amount = _depositAmount
        });

        await LoadAccounts();
    }

    private async Task Withdraw()
    {
        await Http.PostAsJsonAsync("api/accounts/withdraw", new
        {
            accountId = _withdrawAccountId,
            amount = _withdrawAmount
        });

        await LoadAccounts();
    }

    private async Task Transfer()
    {
        await Http.PostAsJsonAsync("api/accounts/transfer", new
        {
            fromAccountId = _fromAccountId,
            toAccountId = _toAccountId,
            amount = _transferAmount
        });

        await LoadAccounts();
    }

    public class AccountDto
    {
        public int AccountId { get; set; }
        public decimal Balance { get; set; }
    }
}