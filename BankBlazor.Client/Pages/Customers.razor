@page "/customers"
@inject BankBlazor.Client.Services.CustomersApi Api

<h3>Alla kunder</h3>

@if (_result != null)
{
    <p>Antal kunder på sidan: @_result.Items.Count</p>
}

@if (_loading)
{
    <p>Laddar...</p>
}
else if (_result is null)
{
    <p>Inga data.</p>
}
else
{
    <p>Visar sida @_page (pageSize @_pageSize). Totalt: @_result.TotalCount</p>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Namn</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in _result.Items)
            {
                <tr>
                    <td>@c.CustomerId</td>
                    <td>
                        <a href="/dashboard/@c.CustomerId">
                            @c.FirstName @c.LastName
                        </a>
                    </td>
                   
                </tr>
            }
        </tbody>
    </table>

    <button @onclick="Prev" disabled="@(_page <= 1)">Föregående</button>
    <button @onclick="Next" disabled="@(_result.Items.Count < _pageSize)">Nästa</button>
}

@code {
    private bool _loading = true;

    private int _page = 1;
    private int _pageSize = 50;

    private BankBlazor.Client.Models.PagedResult<BankBlazor.Client.Models.CustomerDto>? _result;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        StateHasChanged();

        _result = await Api.GetCustomers(_page, _pageSize);

        _loading = false;
    }

    private async Task Prev()
    {
        if (_page <= 1) return;
        _page--;
        await Load();
    }

    private async Task Next()
    {
        _page++;
        await Load();
    }

    public class PagedResult<T>
    {
        public int Page { get; set; }
        public int PageSize { get; set; }
        public int TotalCount { get; set; }
        public List<T> Items { get; set; } = new();
    }

    public class Customer
    {
        public int CustomerId { get; set; }
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
		public string emailAddress { get; set; }
    }
}