@page "/"
@inject HttpClient Http

<PageTitle>Home</PageTitle>

<section class="hero-container">
    <div class="hero-content">
        <img src="/images/hero.jpg" class="hero-img">
    </div>
</section>

<section id="greeting" class="container">
    @if (_loading)
    {
        <h2>Hello Admin! Loading next Scottish bank holiday...</h2>
    }
    else if (!string.IsNullOrWhiteSpace(_holiday))
    {
        <h2>Hello Admin! The next Scottish bank holiday is <strong>@_holiday</strong> on <strong>@_date</strong></h2>
    }
    else
    {
        <h2>Hello Admin! Could not load bank holiday.</h2>
    }
</section>

<section id="dashboard" class="container">
    <h2>Customer Dashboard</h2>
    <div class="info">
        <p>Go to the customer list to view customer details and accounts.</p>
    </div>
</section>

<section id="transactions" class="container">
    <h2>Account Transactions</h2>
    <div class="account">
        <p>Go to the transactions page to make deposits, withdrawals and transfers.</p>
    </div>
</section>

@code {
    private bool _loading = true;
    private string? _holiday;
    private string? _date;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<BankHolidayDto>("api/BankHoliday/next-scottish");

            if (result != null)
            {
                _holiday = result.Holiday;
                _date = result.Date;
            }
        }
        catch
        {
            _holiday = null;
            _date = null;
        }

        _loading = false;
    }

    public class BankHolidayDto
    {
        public string? Holiday { get; set; }
        public string? Date { get; set; }
    }
}