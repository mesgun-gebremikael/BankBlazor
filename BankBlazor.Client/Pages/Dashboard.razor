@page "/dashboard/{CustomerId:int}"
@inject HttpClient Http

<p>
    <a href="/customers">← Tillbaka till kunder</a>
</p>

@if (_loading)
{
    <p>Laddar...</p>
}
else if (_customer is null)
{
    <p>Hittade ingen kund.</p>
}
else
{
    <h4>
        @_customer.FirstName @_customer.LastName
        <small>(Id: @_customer.CustomerId)</small>
    </h4>
    <p><b>Email:</b> @_customer.EmailAddress</p>

    <h5>Adresser</h5>

    @if (_customer.Addresses is null || _customer.Addresses.Count == 0)
    {
        <p>Inga adresser.</p>
    }
    else
    {
        <ul>
            @foreach (var a in _customer.Addresses)
            {
                <li>@a.AddressLine1, @a.City, @a.CountryRegion</li>
            }
        </ul>
    }

    <hr />
    <h5>Senaste orders</h5>

    @if (_customer.Orders is null || _customer.Orders.Count == 0)
    {
        <p>Inga orders.</p>
    }
    else
    {
        <p><b>Antal orders:</b> @_customer.Orders.Count</p>
        <p><b>Total summa:</b> @_customer.Orders.Sum(o => o.TotalDue).ToString("C")</p>

        <table class="table">
            <thead>
                <tr>
                    <th>OrderId</th>
                    <th>Datum</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in _customer.Orders)
                {
                    <tr>
                        <td>
                            <a href="/order/@o.SalesOrderId">
                                @o.SalesOrderId
                            </a>
                        </td>
                        <td>@o.OrderDate.ToShortDateString()</td>
                        <td>@o.TotalDue.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter] public int CustomerId { get; set; }

    private bool _loading = true;
    private CustomerDto? _customer;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        _customer = await Http.GetFromJsonAsync<CustomerDto>($"api/customers/{CustomerId}");

        _loading = false;
    }

    public class CustomerDto
    {
        public int CustomerId { get; set; }
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? EmailAddress { get; set; }
        public List<AddressDto> Addresses { get; set; } = new();
        public List<OrderDto> Orders { get; set; } = new();
    }

    public class AddressDto
    {
        public string? AddressLine1 { get; set; }
        public string? City { get; set; }
        public string? CountryRegion { get; set; }
    }

    public class OrderDto
    {
        public int SalesOrderId { get; set; }
        public DateTime OrderDate { get; set; }
        public decimal TotalDue { get; set; }
    }
}