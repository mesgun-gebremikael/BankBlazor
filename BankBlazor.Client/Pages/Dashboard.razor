@page "/dashboard/{CustomerId:int}"
@inject HttpClient Http

<p>
    <a href="/customers">← Tillbaka till kunder</a>
</p>

@if (_loading)
{
    <p>Laddar kundinformation...</p>
}
else if (_customer is null)
{
    <p>Hittade ingen kund.</p>
}
else
{
    <h4>
        @_customer.FirstName @_customer.LastName
        <small>(Id: @_customer.CustomerId)</small>
    </h4>

    <p><b>Email:</b> @_customer.EmailAddress</p>

    <h5>Adresser</h5>

    @if (_customer.Addresses is null || _customer.Addresses.Count == 0)
    {
        <p>Inga adresser.</p>
    }
    else
    {
        <ul>
            @foreach (var a in _customer.Addresses)
            {
                <li>@a.AddressLine1, @a.City, @a.CountryRegion</li>
            }
        </ul>
    }

    <hr />

    <h5>Kundens konton</h5>

    @if (_customer.Accounts is null || _customer.Accounts.Count == 0)
    {
        <p>Inga konton.</p>
    }
    else
    {
        <p><b>Antal konton:</b> @_customer.Accounts.Count</p>

        <table class="table">
            <thead>
                <tr>
                    <th>Kontonummer</th>
                    <th>Saldo</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in _customer.Accounts)
                {
                    <tr>
                        <td>@a.AccountId</td>
                        <td>@a.Balance.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    [Parameter] public int CustomerId { get; set; }

    private bool _loading = true;
    private CustomerDto? _customer;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        _customer = await Http.GetFromJsonAsync<CustomerDto>($"api/customers/{CustomerId}");

        _loading = false;
    }

    public class CustomerDto
    {
        public int CustomerId { get; set; }
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? EmailAddress { get; set; }
        public List<AddressDto> Addresses { get; set; } = new();
        public List<AccountDto> Accounts { get; set; } = new();
    }

    public class AddressDto
    {
        public string? AddressLine1 { get; set; }
        public string? City { get; set; }
        public string? CountryRegion { get; set; }
    }

    public class AccountDto
    {
        public int AccountId { get; set; }
        public decimal Balance { get; set; }
    }
}